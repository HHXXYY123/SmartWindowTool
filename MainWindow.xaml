<ui:FluentWindow x:Class="SmartWindowTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Smart Window Tool" Height="450" Width="600"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar Grid.Row="0" Title="Smart Window Tool" />
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,20">
                <TextBlock Text="Smart Window Tool 已启动" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="使用快捷键呼出智能菜单：" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20" MaxWidth="550">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <!-- Dummy element to prevent CheckBox from grabbing focus and rendering weirdly -->
                            <Button Width="0" Height="0" Opacity="0" IsTabStop="True" />
                            <CheckBox Content="Ctrl" IsChecked="{Binding Settings.RequireCtrl}" Margin="0,0,20,0" FocusVisualStyle="{x:Null}"/>
                            <CheckBox Content="Shift" IsChecked="{Binding Settings.RequireShift}" Margin="0,0,20,0" FocusVisualStyle="{x:Null}"/>
                            <CheckBox Content="Alt" IsChecked="{Binding Settings.RequireAlt}" Margin="0,0,20,0" FocusVisualStyle="{x:Null}"/>
                            <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="18"/>
                            <ComboBox SelectedValue="{Binding Settings.TriggerButton}" SelectedValuePath="Content" Width="120">
                                <ComboBoxItem Content="Right" />
                                <ComboBoxItem Content="Middle" />
                                <ComboBoxItem Content="Left" />
                            </ComboBox>
                        </StackPanel>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="开机自启动" IsChecked="{Binding Settings.AutoStart}" HorizontalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Content="静默启动 (仅托盘)" IsChecked="{Binding Settings.SilentStart}" HorizontalAlignment="Center"/>
                            <CheckBox Grid.Column="2" Content="管理员权限 (支持游戏)" IsChecked="{Binding Settings.RunAsAdmin}" Click="RunAsAdmin_Click" HorizontalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Button Content="完全退出程序" Appearance="Danger" Click="ExitApp_Click" MinWidth="150" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="自定义窗口尺寸" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,30" MaxWidth="550">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" x:Name="NewSizeTitle" PlaceholderText="标题 (如 1920x1080)" Margin="0,0,10,0" />
                            <ui:TextBox Grid.Column="1" x:Name="NewSizeWidth" PlaceholderText="宽" Margin="0,0,10,0" />
                            <ui:TextBox Grid.Column="2" x:Name="NewSizeHeight" PlaceholderText="高" Margin="0,0,10,0" />
                            <ui:Button Grid.Column="3" Content="添加尺寸" Appearance="Primary" Click="AddSize_Click" />
                        </Grid>
                        <ListBox ItemsSource="{Binding Settings.CustomWindowSizes}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="14" />
                                        <ui:Button Grid.Column="1" Content="删除" Appearance="Danger" Click="RemoveSize_Click" CommandParameter="{Binding}" Padding="15,4" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="进程黑名单过滤" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,30" MaxWidth="550">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" x:Name="BlacklistInput" PlaceholderText="输入进程名，如 LeagueOfLegends.exe" Margin="0,0,10,0"/>
                            <ui:Button Grid.Column="1" Content="添加黑名单" Appearance="Primary" Click="AddBlacklist_Click"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Settings.BlacklistProcesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="14" />
                                        <ui:Button Grid.Column="1" Content="删除" Appearance="Danger" Padding="15,4" Click="RemoveBlacklist_Click" CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <StackPanel Visibility="{Binding HiddenWindowsVisibility}">
                    <TextBlock Text="已隐藏/最小化到托盘的窗口" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center" />
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10" MaxWidth="550">
                        <ListBox ItemsSource="{Binding HiddenWindows}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" ToolTip="{Binding DisplayText}" />
                                            <TextBlock Text="{Binding HiddenAt, StringFormat='隐藏时间: {0:HH:mm:ss}'}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Content="还原窗口" Appearance="Primary" Click="RestoreWindow_Click" CommandParameter="{Binding}" VerticalAlignment="Center" Margin="10,0,0,0" Padding="15,6" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>