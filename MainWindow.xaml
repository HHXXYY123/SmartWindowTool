<ui:FluentWindow x:Class="SmartWindowTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Smart Window Tool" Height="450" Width="600"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar Grid.Row="0" Title="Smart Window Tool" />
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,20">
                <TextBlock Text="Smart Window Tool 已启动" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="使用快捷键呼出智能菜单：" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <CheckBox Content="Ctrl" IsChecked="{Binding Settings.RequireCtrl}" Margin="0,0,10,0"/>
                            <CheckBox Content="Shift" IsChecked="{Binding Settings.RequireShift}" Margin="0,0,10,0"/>
                            <CheckBox Content="Alt" IsChecked="{Binding Settings.RequireAlt}" Margin="0,0,10,0"/>
                            <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox SelectedValue="{Binding Settings.TriggerButton}" SelectedValuePath="Content" Width="120">
                                <ComboBoxItem Content="Right" />
                                <ComboBoxItem Content="Middle" />
                                <ComboBoxItem Content="Left" />
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <CheckBox Content="开机自启动" IsChecked="{Binding Settings.AutoStart}" Margin="0,0,20,0"/>
                            <CheckBox Content="静默启动 (仅托盘运行)" IsChecked="{Binding Settings.SilentStart}" Margin="0,0,20,0"/>
                            <ui:Button Content="完全退出程序" Appearance="Danger" Click="ExitApp_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="自定义窗口尺寸" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,30" Width="500">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:TextBox x:Name="NewSizeTitle" PlaceholderText="标题 (如 1920x1080)" Width="150" Margin="0,0,10,0" />
                            <ui:TextBox x:Name="NewSizeWidth" PlaceholderText="宽" Width="80" Margin="0,0,10,0" />
                            <ui:TextBox x:Name="NewSizeHeight" PlaceholderText="高" Width="80" Margin="0,0,10,0" />
                            <ui:Button Content="添加尺寸" Appearance="Primary" Click="AddSize_Click" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Settings.CustomWindowSizes}" MaxHeight="150" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                        <ui:Button Grid.Column="1" Content="删除" Appearance="Danger" Click="RemoveSize_Click" CommandParameter="{Binding}" Padding="10,2" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="进程黑名单过滤：" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:TextBox x:Name="BlacklistInput" PlaceholderText="输入进程名，如 LeagueOfLegends.exe" Width="250" Margin="0,0,10,0"/>
                            <ui:Button Content="添加黑名单" Click="AddBlacklist_Click"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Settings.BlacklistProcesses}" MaxHeight="150" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ItemsControl.Template>
                                <ControlTemplate>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        <ui:Button Grid.Column="1" Content="删除" Appearance="Danger" Padding="5,2" MinHeight="24" Click="RemoveBlacklist_Click" CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <StackPanel Visibility="{Binding HiddenWindowsVisibility}">
                    <TextBlock Text="已隐藏/最小化到托盘的窗口：" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center" />
                    <ListBox ItemsSource="{Binding HiddenWindows}" MaxHeight="200" Width="500" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding DisplayText}" />
                                        <TextBlock Text="{Binding HiddenAt, StringFormat='隐藏时间: {0:HH:mm:ss}'}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="还原窗口" Appearance="Primary" Click="RestoreWindow_Click" CommandParameter="{Binding}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>