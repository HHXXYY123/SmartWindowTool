<Window x:Class="SmartWindowTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:SmartWindowTool.Controls"
        Title="Smart Window Tool"
        Width="960"
        Height="700"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        TextOptions.TextHintingMode="Fixed"
        KeyboardNavigation.TabNavigation="Continue">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}" />
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{DynamicResource ContentBackgroundColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{DynamicResource SurfaceHoverColor}" />
        <SolidColorBrush x:Key="StrokeBrush" Color="{DynamicResource StrokeColor}" />
        <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextColor}" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="{DynamicResource SecondaryTextColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="{DynamicResource AccentBorderColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
        <SolidColorBrush x:Key="SuccessSoftBrush" Color="{DynamicResource SuccessSoftColor}" />
        <SolidColorBrush x:Key="SuccessBorderBrush" Color="{DynamicResource SuccessBorderColor}" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="{DynamicResource SuccessTextColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource WarningSoftColor}" />
        <SolidColorBrush x:Key="SettingsBrush" Color="{DynamicResource SettingsColor}" />
        <SolidColorBrush x:Key="SettingsSoftBrush" Color="{DynamicResource SettingsSoftColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource DangerSoftColor}" />
        <SolidColorBrush x:Key="DangerBorderBrush" Color="{DynamicResource DangerBorderColor}" />
        <SolidColorBrush x:Key="DangerTextBrush" Color="{DynamicResource DangerTextColor}" />

        <Style x:Key="NavTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="NavItem"
                                Margin="12,3"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="ActiveRail"
                                        Width="3"
                                        Height="24"
                                        Margin="-15,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="0,2,2,0"
                                        Visibility="Collapsed" />
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ActiveRail" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="NavItem" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="25" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,13" />
        </Style>

        <Style x:Key="SectionStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,24" />
            <Setter Property="Margin" Value="0,0,0,24" />
        </Style>

        <Style x:Key="ShortcutCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18,15" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="2,14" />
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="11,6,5,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Smart Window Tool"
                     Background="{StaticResource AppBackgroundBrush}" />

        <TabControl Grid.Row="1"
                    TabStripPlacement="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="0"
                    KeyboardNavigation.DirectionalNavigation="Contained">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="214" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource SidebarBackgroundBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Margin="20,21,16,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource AccentSoftBrush}"
                                            BorderBrush="{StaticResource AccentBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <ui:SymbolIcon Symbol="WindowMultiple20"
                                                       FontSize="20"
                                                       Foreground="{StaticResource AccentBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="SMART WINDOW"
                                                   FontFamily="Segoe UI Semibold"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <TextBlock Text="桌面控制"
                                                   Margin="0,2,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </Grid>

                                <TabPanel Grid.Row="1"
                                          Margin="0,2,0,0"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1" />

                                <Border Grid.Row="2"
                                        Margin="18,16,18,20"
                                        Padding="11,9"
                                        Background="{StaticResource SuccessSoftBrush}"
                                        BorderBrush="{StaticResource SuccessBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Margin="0,0,9,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="后台服务运行中"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SuccessTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource ContentBackgroundBrush}"
                                TextElement.Foreground="{StaticResource PrimaryTextBrush}">
                            <ContentPresenter Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectedContentStringFormat}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Style="{StaticResource NavTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Keyboard20" FontSize="19" />
                        <TextBlock Text="快捷键" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Style="{DynamicResource {x:Type ScrollViewer}}">
                    <StackPanel Margin="34,28,38,36">
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" Background="{StaticResource AccentSoftBrush}" CornerRadius="5">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="22" Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="快捷键" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="窗口操作组合键" Style="{StaticResource PageSubtitleStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="全局入口" Style="{StaticResource SectionTitleStyle}" />
                                <Border Style="{StaticResource ShortcutCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="CursorClick20" FontSize="19" Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Text="呼出菜单" Margin="10,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <controls:HotkeyEditor Grid.Row="1"
                                                               Margin="29,14,0,0"
                                                               DataContext="{Binding Settings.MenuHotkey}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="滚轮调节" Style="{StaticResource SectionTitleStyle}" />
                                <Border Style="{StaticResource ShortcutCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Eye20" FontSize="19" Foreground="{StaticResource SuccessBrush}" />
                                                <TextBlock Text="透明度" Margin="10,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Content="启用"
                                                      IsChecked="{Binding Settings.EnableTransparencyHotkey}" />
                                        </Grid>
                                        <controls:HotkeyEditor Grid.Row="1"
                                                               Margin="29,14,0,0"
                                                               DataContext="{Binding Settings.TransparencyHotkey}"
                                                               IsEnabled="{Binding Settings.EnableTransparencyHotkey}"
                                                               IsMouseWheelMode="True" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource ShortcutCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Resize20" FontSize="19" Foreground="{StaticResource WarningBrush}" />
                                                <TextBlock Text="窗口宽度" Margin="10,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Content="启用"
                                                      IsChecked="{Binding Settings.EnableWidthHotkey}" />
                                        </Grid>
                                        <controls:HotkeyEditor Grid.Row="1"
                                                               Margin="29,14,0,0"
                                                               DataContext="{Binding Settings.WidthHotkey}"
                                                               IsEnabled="{Binding Settings.EnableWidthHotkey}"
                                                               IsMouseWheelMode="True" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource ShortcutCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Resize20" FontSize="19" Foreground="{StaticResource WarningBrush}" />
                                                <TextBlock Text="窗口高度" Margin="10,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Content="启用"
                                                      IsChecked="{Binding Settings.EnableHeightHotkey}" />
                                        </Grid>
                                        <controls:HotkeyEditor Grid.Row="1"
                                                               Margin="29,14,0,0"
                                                               DataContext="{Binding Settings.HeightHotkey}"
                                                               IsEnabled="{Binding Settings.EnableHeightHotkey}"
                                                               IsMouseWheelMode="True" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="附加快捷操作" Style="{StaticResource SectionTitleStyle}" />
                            <Border Style="{StaticResource SettingRowStyle}">
                                <CheckBox Content="Alt + 小键盘数字调整位置与尺寸"
                                          IsChecked="{Binding Settings.EnableAltNumpad}" />
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <CheckBox Content="Ctrl + 小键盘数字调整透明度"
                                          IsChecked="{Binding Settings.EnableCtrlNumpad}" />
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <CheckBox Content="Ctrl + Alt + 方向键移动窗口"
                                          IsChecked="{Binding Settings.EnablePositionArrowKeys}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="WindowMultiple20" FontSize="19" />
                        <TextBlock Text="窗口规则" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Style="{DynamicResource {x:Type ScrollViewer}}">
                    <StackPanel Margin="34,28,38,36">
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" Background="{StaticResource WarningSoftBrush}" CornerRadius="5">
                                <ui:SymbolIcon Symbol="WindowSettings20" FontSize="22" Foreground="{StaticResource WarningBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="窗口规则" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="尺寸预设与进程过滤" Style="{StaticResource PageSubtitleStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="自定义窗口尺寸" Style="{StaticResource SectionTitleStyle}" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox x:Name="NewSizeTitle"
                                                Grid.Column="0"
                                                MinHeight="40"
                                                Margin="0,0,8,0"
                                                PlaceholderText="预设名称" />
                                    <ui:TextBox x:Name="NewSizeWidth"
                                                Grid.Column="1"
                                                MinHeight="40"
                                                Margin="0,0,8,0"
                                                PlaceholderText="宽" />
                                    <ui:TextBox x:Name="NewSizeHeight"
                                                Grid.Column="2"
                                                MinHeight="40"
                                                Margin="0,0,8,0"
                                                PlaceholderText="高" />
                                    <ui:Button Grid.Column="3"
                                               MinHeight="40"
                                               Padding="14,0"
                                               Appearance="Primary"
                                               Content="添加"
                                               Icon="{ui:SymbolIcon Symbol=Add20}"
                                               Click="AddSize_Click" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Settings.CustomWindowSizes}"
                                              Background="Transparent"
                                              BorderThickness="0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ChipStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               VerticalAlignment="Center" />
                                                    <ui:Button Width="26"
                                                               Height="26"
                                                               MinWidth="26"
                                                               MinHeight="26"
                                                               Margin="7,0,0,0"
                                                               Padding="0"
                                                               Appearance="Transparent"
                                                               Icon="{ui:SymbolIcon Symbol=Dismiss20}"
                                                               ToolTip="删除尺寸"
                                                               AutomationProperties.Name="删除尺寸"
                                                               Click="RemoveSize_Click"
                                                               CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="进程黑名单" Style="{StaticResource SectionTitleStyle}" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="BlacklistInput"
                                            Grid.Column="0"
                                            MinHeight="40"
                                            Margin="0,0,8,0"
                                            PlaceholderText="进程名称，例如 app.exe" />
                                <ui:Button Grid.Column="1"
                                           MinHeight="40"
                                           Margin="0,0,8,0"
                                           Padding="13,0"
                                           Appearance="Secondary"
                                           Content="选择进程"
                                           Icon="{ui:SymbolIcon Symbol=FolderOpen20}"
                                           Click="SelectProcess_Click" />
                                <ui:Button Grid.Column="2"
                                           MinHeight="40"
                                           Padding="14,0"
                                           Appearance="Primary"
                                           Content="添加"
                                           Icon="{ui:SymbolIcon Symbol=Add20}"
                                           Click="AddBlacklist_Click" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Settings.BlacklistProcesses}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ShieldProhibited20"
                                                               Margin="0,0,7,0"
                                                               Foreground="{StaticResource DangerBrush}" />
                                                <TextBlock Text="{Binding}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           VerticalAlignment="Center" />
                                                <ui:Button Width="26"
                                                           Height="26"
                                                           MinWidth="26"
                                                           MinHeight="26"
                                                           Margin="7,0,0,0"
                                                           Padding="0"
                                                           Appearance="Transparent"
                                                           Icon="{ui:SymbolIcon Symbol=Dismiss20}"
                                                           ToolTip="移出黑名单"
                                                           AutomationProperties.Name="移出黑名单"
                                                           Click="RemoveBlacklist_Click"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings20" FontSize="19" />
                        <TextBlock Text="应用设置" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Style="{DynamicResource {x:Type ScrollViewer}}">
                    <StackPanel Margin="34,28,38,36">
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" Background="{StaticResource SettingsSoftBrush}" CornerRadius="5">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="22" Foreground="{StaticResource SettingsBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="应用设置" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="启动、权限与边界行为" Style="{StaticResource PageSubtitleStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="启动" Style="{StaticResource SectionTitleStyle}" />
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Power20" Margin="0,0,11,0" Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Text="开机自启动" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Settings.AutoStart, Mode=OneWay}"
                                                  AutomationProperties.Name="开机自启动"
                                                  Click="AutoStart_Click" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="EyeOff20" Margin="0,0,11,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="静默启动（仅托盘）" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Settings.SilentStart}"
                                                  AutomationProperties.Name="静默启动" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="权限与边界" Style="{StaticResource SectionTitleStyle}" />
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ShieldCheckmark20" Margin="0,0,11,0" Foreground="{StaticResource SuccessBrush}" />
                                            <TextBlock Text="管理员权限（支持游戏）" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Settings.RunAsAdmin}"
                                                  AutomationProperties.Name="管理员权限"
                                                  Click="RunAsAdmin_Click" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Desktop20" Margin="0,0,11,0" Foreground="{StaticResource WarningBrush}" />
                                            <TextBlock Text="忽略任务栏，以屏幕边缘为基准" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Settings.IgnoreTaskbar}"
                                                  AutomationProperties.Name="忽略任务栏" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource DangerSoftBrush}"
                                BorderBrush="{StaticResource DangerBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="17,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Power20" FontSize="20" Foreground="{StaticResource DangerBrush}" />
                                    <TextBlock Text="完全退出程序"
                                               Margin="11,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DangerTextBrush}" />
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           MinWidth="104"
                                           Appearance="Danger"
                                           Content="退出程序"
                                           Icon="{ui:SymbolIcon Symbol=ArrowExit20}"
                                           Click="ExitApp_Click" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}"
                     Visibility="{Binding HiddenWindowsVisibility}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="WindowArrowUp20" FontSize="19" />
                        <TextBlock Text="已隐藏窗口" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Style="{DynamicResource {x:Type ScrollViewer}}">
                    <StackPanel Margin="34,28,38,36">
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" Background="{StaticResource SuccessSoftBrush}" CornerRadius="5">
                                <ui:SymbolIcon Symbol="WindowArrowUp24" FontSize="22" Foreground="{StaticResource SuccessBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="已隐藏窗口" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="当前由 Smart Window 托管的窗口" Style="{StaticResource PageSubtitleStyle}" />
                            </StackPanel>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding HiddenWindows}"
                                      Background="Transparent"
                                      BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ShortcutCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="Window20"
                                                           Margin="0,0,12,0"
                                                           FontSize="19"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding DisplayText}" />
                                                <TextBlock Text="{Binding HiddenAt, StringFormat='隐藏于 {0:HH:mm:ss}'}"
                                                           Margin="0,3,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="2"
                                                       Margin="14,0,0,0"
                                                       Padding="14,6"
                                                       Appearance="Primary"
                                                       Content="还原"
                                                       Icon="{ui:SymbolIcon Symbol=ArrowUndo20}"
                                                       Click="RestoreWindow_Click"
                                                       CommandParameter="{Binding}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border x:Name="WindowFrameBorder"
                Grid.RowSpan="2"
                Panel.ZIndex="200"
                BorderBrush="{DynamicResource WindowBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True" />
    </Grid>
</Window>
