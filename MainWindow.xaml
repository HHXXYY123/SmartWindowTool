<ui:FluentWindow x:Class="SmartWindowTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:SmartWindowTool.Controls"
        Title="Smart Window Tool" Height="500" Width="680"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar Grid.Row="0" Title="Smart Window Tool" />
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0" Margin="0" Style="{DynamicResource {x:Type ScrollViewer}}">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="40,20,40,40">
                <TextBlock Text="Smart Window Tool" FontSize="28" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                <TextBlock Text="配置使用快捷键呼出智能菜单等功能：" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Left" Margin="0,0,0,20"/>
                
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,30" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="呼出智能菜单:" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <controls:HotkeySelector Grid.Column="1" DataContext="{Binding Settings.MenuHotkey}" />
                        </Grid>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="调节窗口透明度:" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <controls:HotkeySelector Grid.Column="1" DataContext="{Binding Settings.TransparencyHotkey}" HideMouseSelector="True" />
                            <CheckBox Grid.Column="2" Content="启用" IsChecked="{Binding Settings.EnableTransparencyWheel}" Margin="10,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="调节窗口高度:" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <controls:HotkeySelector Grid.Column="1" DataContext="{Binding Settings.HeightHotkey}" HideMouseSelector="True" />
                            <CheckBox Grid.Column="2" Content="启用" IsChecked="{Binding Settings.EnableSizeWheel}" Margin="10,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="调节窗口宽度:" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <controls:HotkeySelector Grid.Column="1" DataContext="{Binding Settings.WidthHotkey}" HideMouseSelector="True" />
                            <CheckBox Grid.Column="2" Content="启用" IsChecked="{Binding Settings.EnableSizeWheel}" Margin="10,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="快捷对齐 (小键盘):" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Alt + 1~9" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,15,0" />
                                <CheckBox Content="启用对齐" IsChecked="{Binding Settings.EnableNumpadAlign}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="快捷透明 (小键盘):" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Ctrl + 0~9" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,15,0" />
                                <CheckBox Content="启用透明" IsChecked="{Binding Settings.EnableNumpadMove}" />
                            </StackPanel>
                        </Grid>
                        
                        <Separator Margin="0,10,0,20" />

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="开机自启动" IsChecked="{Binding Settings.AutoStart}" HorizontalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Content="静默启动 (仅托盘)" IsChecked="{Binding Settings.SilentStart}" HorizontalAlignment="Center"/>
                            <CheckBox Grid.Column="2" Content="管理员权限 (支持游戏)" IsChecked="{Binding Settings.RunAsAdmin}" Click="RunAsAdmin_Click" HorizontalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Button Content="完全退出程序" Appearance="Danger" Click="ExitApp_Click" MinWidth="150" />
                        </StackPanel>
                    </StackPanel>
                </Border>"}]}

                <TextBlock Text="自定义窗口尺寸" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Left" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,30" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" x:Name="NewSizeTitle" PlaceholderText="标题 (如 1920x1080)" Margin="0,0,10,0" />
                            <ui:TextBox Grid.Column="1" x:Name="NewSizeWidth" PlaceholderText="宽" Margin="0,0,10,0" />
                            <ui:TextBox Grid.Column="2" x:Name="NewSizeHeight" PlaceholderText="高" Margin="0,0,10,0" />
                            <ui:Button Grid.Column="3" Content="添加尺寸" Appearance="Primary" Click="AddSize_Click" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Settings.CustomWindowSizes}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="10,6" Margin="0,0,10,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                                            <ui:Button Content="✕" Appearance="Transparent" Padding="4,0" MinHeight="20" Click="RemoveSize_Click" CommandParameter="{Binding}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="进程黑名单过滤" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Left" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,30" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" x:Name="BlacklistInput" PlaceholderText="输入进程名，如 LeagueOfLegends.exe" Margin="0,0,10,0"/>
                            <ui:Button Grid.Column="1" Content="添加黑名单" Appearance="Primary" Click="AddBlacklist_Click"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Settings.BlacklistProcesses}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="10,6" Margin="0,0,10,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                                            <ui:Button Content="✕" Appearance="Transparent" Padding="4,0" MinHeight="20" Click="RemoveBlacklist_Click" CommandParameter="{Binding}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <StackPanel Visibility="{Binding HiddenWindowsVisibility}">
                    <TextBlock Text="已隐藏/最小化到托盘的窗口" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Left" />
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,30" HorizontalAlignment="Stretch">
                        <ItemsControl ItemsSource="{Binding HiddenWindows}" Background="Transparent" BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" ToolTip="{Binding DisplayText}" />
                                            <TextBlock Text="{Binding HiddenAt, StringFormat='隐藏时间: {0:HH:mm:ss}'}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Content="还原窗口" Appearance="Primary" Click="RestoreWindow_Click" CommandParameter="{Binding}" VerticalAlignment="Center" Margin="10,0,0,0" Padding="15,6" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>