<Window x:Class="SmartWindowTool.Views.FloatingMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Smart Menu"
        SizeToContent="WidthAndHeight"
        MaxHeight="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Deactivated="Window_Deactivated"
        Padding="8"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        TextOptions.TextHintingMode="Fixed">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="PopupButtonStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="1" />
        </Style>

        <Style x:Key="MenuSectionStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,5,6,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MenuSectionBrush}" />
        </Style>

        <Style x:Key="MenuDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="6,3,6,1" />
            <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        </Style>
    </Window.Resources>

    <Border MinWidth="292"
            Background="{DynamicResource MenuBackgroundBrush}"
            BorderBrush="{DynamicResource MenuBorderBrush}"
            BorderThickness="1"
            CornerRadius="7"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.24" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="6,3,6,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="28"
                        Height="28"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AccentSoftBrush}"
                        BorderBrush="{DynamicResource AccentBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <ui:SymbolIcon Symbol="WindowWrench20"
                                   FontSize="18"
                                   Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="窗口控制"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MenuHeaderBrush}" />
                    <TextBlock Text="Smart Window Tool"
                               Margin="0,1,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1">
                    <Border Style="{StaticResource MenuDividerStyle}" Margin="6,0,6,2" />

                    <TextBlock Text="尺寸" Style="{StaticResource MenuSectionStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="放大"
                                   Icon="{ui:SymbolIcon Symbol=ArrowMaximize20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="EnlargeWindow_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="缩小"
                                   Icon="{ui:SymbolIcon Symbol=ArrowMinimize20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="ShrinkWindow_Click" />
                    </Grid>

                    <ui:Button x:Name="CustomSizeButton"
                               Style="{StaticResource MenuButtonStyle}"
                               HorizontalContentAlignment="Stretch"
                               MouseEnter="CustomSizeButton_MouseEnter"
                               MouseLeave="CustomSizeButton_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Resize20" Margin="0,0,9,0" />
                            <TextBlock Grid.Column="1" Text="自定义窗口尺寸" VerticalAlignment="Center" />
                            <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight20" Foreground="{DynamicResource SecondaryTextBrush}" />
                        </Grid>
                    </ui:Button>
                    <Popup x:Name="CustomSizePopup"
                           PlacementTarget="{Binding ElementName=CustomSizeButton}"
                           Placement="Right"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           MouseLeave="CustomSizePopup_MouseLeave">
                        <Border Width="192"
                                Background="{DynamicResource MenuBackgroundBrush}"
                                BorderBrush="{DynamicResource MenuBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.22" />
                            </Border.Effect>
                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Settings.CustomWindowSizes}"
                                              Background="Transparent"
                                              BorderThickness="0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="{Binding Title}"
                                                       Style="{StaticResource PopupButtonStyle}"
                                                       Click="CustomSize_Click"
                                                       CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <Border Style="{StaticResource MenuDividerStyle}" />
                    <TextBlock Text="位置" Style="{StaticResource MenuSectionStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="PinButton"
                                   Grid.Column="0"
                                   Content="置顶窗口"
                                   Icon="{ui:SymbolIcon Symbol=Pin20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="PinWindow_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="置底窗口"
                                   Icon="{ui:SymbolIcon Symbol=PositionToBack20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="BottomWindow_Click" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="居中显示"
                                   Icon="{ui:SymbolIcon Symbol=AlignCenterHorizontal20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="CenterWindow_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="贴靠边缘"
                                   Icon="{ui:SymbolIcon Symbol=WindowLocationTarget20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="SnapToEdge_Click" />
                    </Grid>
                    <ui:Button x:Name="MonitorButton"
                               Style="{StaticResource MenuButtonStyle}"
                               HorizontalContentAlignment="Stretch"
                               MouseEnter="MonitorButton_MouseEnter"
                               MouseLeave="MonitorButton_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Desktop20" Margin="0,0,9,0" />
                            <TextBlock Grid.Column="1" Text="移动到显示器" VerticalAlignment="Center" />
                            <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight20" Foreground="{DynamicResource SecondaryTextBrush}" />
                        </Grid>
                    </ui:Button>
                    <Popup x:Name="MonitorPopup"
                           PlacementTarget="{Binding ElementName=MonitorButton}"
                           Placement="Right"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           MouseLeave="MonitorPopup_MouseLeave">
                        <Border Width="192"
                                Background="{DynamicResource MenuBackgroundBrush}"
                                BorderBrush="{DynamicResource MenuBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.22" />
                            </Border.Effect>
                            <ItemsControl x:Name="MonitorList"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button Content="{Binding Name}"
                                                   Icon="{ui:SymbolIcon Symbol=Desktop20}"
                                                   Style="{StaticResource PopupButtonStyle}"
                                                   Click="MoveToMonitor_Click"
                                                   CommandParameter="{Binding Index}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>

                    <Border Style="{StaticResource MenuDividerStyle}" />
                    <TextBlock Text="外观" Style="{StaticResource MenuSectionStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="BorderlessButton"
                                   Grid.Column="0"
                                   Content="移除边框"
                                   Icon="{ui:SymbolIcon Symbol=BorderNone20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="Borderless_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="鼠标穿透"
                                   Icon="{ui:SymbolIcon Symbol=CursorProhibited20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="ClickThrough_Click"
                                   ToolTip="开启后可在主界面恢复鼠标操作" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="RollUpButton"
                                   Grid.Column="0"
                                   Content="卷起窗口"
                                   Icon="{ui:SymbolIcon Symbol=PanelTopContract20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="RollUp_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="冻结截图"
                                   Icon="{ui:SymbolIcon Symbol=Camera20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="FreezeWindow_Click"
                                   ToolTip="按 Esc 或右键关闭截图" />
                    </Grid>
                    <Grid Margin="6,2,6,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="Eye20"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" />
                        <Slider x:Name="TransparencySlider"
                                Grid.Column="1"
                                Minimum="20"
                                Maximum="100"
                                Value="100"
                                ValueChanged="TransparencySlider_ValueChanged"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElementName=TransparencySlider, Path=Value, StringFormat={}{0:0}%}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Style="{StaticResource MenuDividerStyle}" />
                    <TextBlock Text="工具" Style="{StaticResource MenuSectionStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="窗口信息"
                                   Icon="{ui:SymbolIcon Symbol=Info20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="InfoWindow_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="所在目录"
                                   Icon="{ui:SymbolIcon Symbol=FolderOpen20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="OpenFolder_Click" />
                    </Grid>
                    <ui:Button Content="显示主界面"
                               Icon="{ui:SymbolIcon Symbol=WindowSettings20}"
                               Style="{StaticResource MenuButtonStyle}"
                               Click="ShowMainWindow_Click" />

                    <Border Style="{StaticResource MenuDividerStyle}" />
                    <TextBlock Text="窗口" Style="{StaticResource MenuSectionStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="隐藏窗口"
                                   Icon="{ui:SymbolIcon Symbol=EyeOff20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="HideWindow_Click" />
                        <ui:Button Grid.Column="1"
                                   Content="最小化到托盘"
                                   Icon="{ui:SymbolIcon Symbol=ArrowMinimize20}"
                                   Style="{StaticResource MenuButtonStyle}"
                                   Click="MinimizeToTray_Click" />
                    </Grid>
                    <CheckBox Content="忽略任务栏，以屏幕边缘为基准"
                              Margin="8,5,6,5"
                              IsChecked="{Binding Settings.IgnoreTaskbar}"
                              Foreground="{DynamicResource SecondaryTextBrush}" />

                    <ui:Button Content="关闭菜单"
                               Icon="{ui:SymbolIcon Symbol=Dismiss20}"
                               HorizontalAlignment="Stretch"
                               Margin="1,2,1,1"
                               MinHeight="30"
                               Appearance="Danger"
                               Click="CloseMenu_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
