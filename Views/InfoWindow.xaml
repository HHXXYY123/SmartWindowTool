<Window x:Class="SmartWindowTool.Views.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="窗口信息" MinHeight="280" Width="520" MaxHeight="620"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="InfoTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,2,0,2" />
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="窗口信息" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                <ui:Button Grid.Column="1" Content="✕" HorizontalAlignment="Right" Appearance="Transparent" Click="CloseButton_Click" Padding="5,2" MinHeight="24" BorderThickness="0" />
            </Grid>

            <!-- Content (scrollable) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,5,20,10">
                <StackPanel>
                    <TextBlock Text="💡 单击复制内容 | 双击或拖动可选文本" Style="{StaticResource InfoLabel}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="窗口句柄 (Handle):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtHandle" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 TextWrapping="NoWrap" PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="窗口标题 (Title):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtTitle" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="窗口类名 (Class):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtClass" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="进程 ID (PID):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtPid" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 TextWrapping="NoWrap" PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="进程名称 (Name):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtProcessName" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                    </Grid>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="进程路径 (Path):" Style="{StaticResource InfoLabel}"/>
                        <TextBox x:Name="TxtProcessPath" Grid.Column="1" Style="{StaticResource InfoTextBox}"
                                 PreviewMouseLeftButtonUp="InfoTextBox_PreviewMouseLeftButtonUp"/>
                        <ui:Button Grid.Column="2" Content="📂" Appearance="Secondary" Margin="8,0,0,0" Padding="8,4" MinHeight="28"
                                   ToolTip="打开所在目录" Click="OpenPathFolder_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Button -->
            <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="0,0,8,8" Padding="15,10">
                <ui:Button Content="复制全部并关闭" HorizontalAlignment="Right" Appearance="Primary" Click="CopyAndCloseButton_Click" MinWidth="120"/>
            </Border>
        </Grid>
    </Border>
</Window>