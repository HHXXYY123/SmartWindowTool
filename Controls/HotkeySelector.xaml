<UserControl x:Class="SmartWindowTool.Controls.HotkeySelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <ComboBox SelectedValue="{Binding Modifier1}" SelectedValuePath="Content" Width="80" FocusVisualStyle="{x:Null}" IsTabStop="False" Margin="0,0,10,0">
            <ComboBoxItem Content="None" />
            <ComboBoxItem Content="Shift" />
            <ComboBoxItem Content="Ctrl" />
            <ComboBoxItem Content="Alt" />
            <ComboBoxItem Content="WinL" />
            <ComboBoxItem Content="WinR" />
        </ComboBox>
        <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <ComboBox SelectedValue="{Binding Modifier2}" SelectedValuePath="Content" Width="80" FocusVisualStyle="{x:Null}" IsTabStop="False" Margin="0,0,10,0">
            <ComboBoxItem Content="None" />
            <ComboBoxItem Content="Shift" />
            <ComboBoxItem Content="Ctrl" />
            <ComboBoxItem Content="Alt" />
            <ComboBoxItem Content="WinL" />
            <ComboBoxItem Content="WinR" />
        </ComboBox>
        <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <ComboBox SelectedValue="{Binding Key}" SelectedValuePath="Content" Width="90" FocusVisualStyle="{x:Null}" IsTabStop="False" Margin="0,0,10,0">
            <ComboBoxItem Content="None" />
            <ComboBoxItem Content="Backspace" />
            <ComboBoxItem Content="Tab" />
            <ComboBoxItem Content="Enter" />
            <ComboBoxItem Content="Pause" />
            <ComboBoxItem Content="CapsLock" />
            <ComboBoxItem Content="Escape" />
            <ComboBoxItem Content="Space" />
            <ComboBoxItem Content="PageUp" />
            <ComboBoxItem Content="PageDown" />
            <ComboBoxItem Content="End" />
            <ComboBoxItem Content="Home" />
            <ComboBoxItem Content="Left" />
            <ComboBoxItem Content="Up" />
            <ComboBoxItem Content="Right" />
            <ComboBoxItem Content="Down" />
            <ComboBoxItem Content="PrintScreen" />
            <ComboBoxItem Content="Insert" />
            <ComboBoxItem Content="Delete" />
            <ComboBoxItem Content="A" />
            <ComboBoxItem Content="B" />
            <ComboBoxItem Content="C" />
            <ComboBoxItem Content="D" />
            <ComboBoxItem Content="E" />
            <ComboBoxItem Content="F" />
            <ComboBoxItem Content="G" />
            <ComboBoxItem Content="H" />
            <ComboBoxItem Content="I" />
            <ComboBoxItem Content="J" />
            <ComboBoxItem Content="K" />
            <ComboBoxItem Content="L" />
            <ComboBoxItem Content="M" />
            <ComboBoxItem Content="N" />
            <ComboBoxItem Content="O" />
            <ComboBoxItem Content="P" />
            <ComboBoxItem Content="Q" />
            <ComboBoxItem Content="R" />
            <ComboBoxItem Content="S" />
            <ComboBoxItem Content="T" />
            <ComboBoxItem Content="U" />
            <ComboBoxItem Content="V" />
            <ComboBoxItem Content="W" />
            <ComboBoxItem Content="X" />
            <ComboBoxItem Content="Y" />
            <ComboBoxItem Content="Z" />
            <ComboBoxItem Content="D0" />
            <ComboBoxItem Content="D1" />
            <ComboBoxItem Content="D2" />
            <ComboBoxItem Content="D3" />
            <ComboBoxItem Content="D4" />
            <ComboBoxItem Content="D5" />
            <ComboBoxItem Content="D6" />
            <ComboBoxItem Content="D7" />
            <ComboBoxItem Content="D8" />
            <ComboBoxItem Content="D9" />
        </ComboBox>
        <TextBlock x:Name="TxtMousePlus" Text="+" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <ComboBox x:Name="CmbMouse" SelectedValue="{Binding MouseButton}" SelectedValuePath="Content" Width="90" FocusVisualStyle="{x:Null}" IsTabStop="False">
            <ComboBoxItem Content="Right" />
            <ComboBoxItem Content="Left" />
            <ComboBoxItem Content="Middle" />
            <ComboBoxItem Content="XButton1" />
            <ComboBoxItem Content="XButton2" />
            <ComboBoxItem Content="Wheel" />
            <ComboBoxItem Content="None" />
        </ComboBox>
    </StackPanel>
</UserControl>