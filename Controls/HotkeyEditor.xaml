<UserControl x:Class="SmartWindowTool.Controls.HotkeyEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
    <Grid IsEnabled="{Binding IsEnabled}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="键 1" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox SelectedValue="{Binding Modifier1}" SelectedValuePath="Content" Width="80">
                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="Shift"/>
                <ComboBoxItem Content="Ctrl"/>
                <ComboBoxItem Content="Alt"/>
                <ComboBoxItem Content="WinL"/>
                <ComboBoxItem Content="WinR"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
            <TextBlock Text="键 2" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox SelectedValue="{Binding Modifier2}" SelectedValuePath="Content" Width="80">
                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="Shift"/>
                <ComboBoxItem Content="Ctrl"/>
                <ComboBoxItem Content="Alt"/>
                <ComboBoxItem Content="WinL"/>
                <ComboBoxItem Content="WinR"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,10,0">
            <TextBlock Text="键 3" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding AvailableKeys, ElementName=Root}" SelectedItem="{Binding Key1}" Width="100"/>
        </StackPanel>
        <StackPanel Grid.Column="3" Margin="0,0,10,0">
            <TextBlock Text="键 4" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding AvailableKeys, ElementName=Root}" SelectedItem="{Binding Key2}" Width="100"/>
        </StackPanel>
        <StackPanel Grid.Column="4" Visibility="{Binding ShowMouseButton, ElementName=Root}">
            <TextBlock Text="鼠标按钮" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox SelectedValue="{Binding MouseButton}" SelectedValuePath="Content" Width="80">
                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Right"/>
                <ComboBoxItem Content="Middle"/>
                <ComboBoxItem Content="XButton1"/>
                <ComboBoxItem Content="XButton2"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="4" Visibility="{Binding ShowMouseWheel, ElementName=Root}" VerticalAlignment="Bottom" Margin="0,0,0,5">
            <TextBlock Text="+ 鼠标滚轮" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>