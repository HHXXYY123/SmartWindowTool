<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#F4F6F8</Color>
    <Color x:Key="SidebarBackgroundColor">#EAEEF2</Color>
    <Color x:Key="ContentBackgroundColor">#F8FAFB</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#E8EEF4</Color>
    <Color x:Key="StrokeColor">#CDD5DE</Color>
    <Color x:Key="DividerColor">#DCE2E8</Color>
    <Color x:Key="PrimaryTextColor">#18212A</Color>
    <Color x:Key="SecondaryTextColor">#5D6874</Color>
    <Color x:Key="AccentColor">#00789F</Color>
    <Color x:Key="AccentSoftColor">#D8EFF8</Color>
    <Color x:Key="AccentBorderColor">#83C9E0</Color>
    <Color x:Key="SuccessColor">#117A52</Color>
    <Color x:Key="SuccessSoftColor">#DFF3EA</Color>
    <Color x:Key="SuccessBorderColor">#A8D8C4</Color>
    <Color x:Key="SuccessTextColor">#285F49</Color>
    <Color x:Key="WarningColor">#A65D00</Color>
    <Color x:Key="WarningSoftColor">#FDF0D8</Color>
    <Color x:Key="SettingsColor">#5B5FC7</Color>
    <Color x:Key="SettingsSoftColor">#E8E8FA</Color>
    <Color x:Key="DangerColor">#C42B32</Color>
    <Color x:Key="DangerSoftColor">#FBE9EA</Color>
    <Color x:Key="DangerBorderColor">#E3B0B3</Color>
    <Color x:Key="DangerTextColor">#8C1D22</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="{StaticResource SuccessBorderColor}" />
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}" />
    <SolidColorBrush x:Key="SettingsBrush" Color="{StaticResource SettingsColor}" />
    <SolidColorBrush x:Key="SettingsSoftBrush" Color="{StaticResource SettingsSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="{StaticResource DangerBorderColor}" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerTextColor}" />

    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#C7D0D9" />
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#C7D0D9" />
    <SolidColorBrush x:Key="MenuSectionBrush" Color="#66727F" />
    <SolidColorBrush x:Key="MenuHeaderBrush" Color="#16313D" />
</ResourceDictionary>
