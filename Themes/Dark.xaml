<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#17191D</Color>
    <Color x:Key="SidebarBackgroundColor">#1C1F24</Color>
    <Color x:Key="ContentBackgroundColor">#181B1F</Color>
    <Color x:Key="SurfaceColor">#21252B</Color>
    <Color x:Key="SurfaceHoverColor">#282D34</Color>
    <Color x:Key="StrokeColor">#323840</Color>
    <Color x:Key="DividerColor">#2A2F36</Color>
    <Color x:Key="PrimaryTextColor">#F4F7FA</Color>
    <Color x:Key="SecondaryTextColor">#9CA7B2</Color>
    <Color x:Key="AccentColor">#52C7EA</Color>
    <Color x:Key="AccentSoftColor">#173844</Color>
    <Color x:Key="AccentBorderColor">#286276</Color>
    <Color x:Key="SuccessColor">#57D6A0</Color>
    <Color x:Key="SuccessSoftColor">#1E332D</Color>
    <Color x:Key="SuccessBorderColor">#2E4B40</Color>
    <Color x:Key="SuccessTextColor">#A8D9C4</Color>
    <Color x:Key="WarningColor">#F3B657</Color>
    <Color x:Key="WarningSoftColor">#312B1F</Color>
    <Color x:Key="SettingsColor">#AAB4FF</Color>
    <Color x:Key="SettingsSoftColor">#282A3D</Color>
    <Color x:Key="DangerColor">#FF7676</Color>
    <Color x:Key="DangerSoftColor">#382225</Color>
    <Color x:Key="DangerBorderColor">#6A3439</Color>
    <Color x:Key="DangerTextColor">#FFD4D4</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="{StaticResource SuccessBorderColor}" />
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}" />
    <SolidColorBrush x:Key="SettingsBrush" Color="{StaticResource SettingsColor}" />
    <SolidColorBrush x:Key="SettingsSoftBrush" Color="{StaticResource SettingsSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="{StaticResource DangerBorderColor}" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerTextColor}" />

    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#1C2025" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#343B44" />
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#343B44" />
    <SolidColorBrush x:Key="MenuSectionBrush" Color="#8F9AA6" />
    <SolidColorBrush x:Key="MenuHeaderBrush" Color="#EDF6FA" />
</ResourceDictionary>
